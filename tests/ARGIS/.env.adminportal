# Configuración de ArcGIS Enterprise - Cuenta Adminportal
# (duplicado de datos para segunda cuenta del portal)
ARCGIS_PORTAL_URL=https://arcgisenterprise.minenergia.gov.co/portal/
ARCGIS_USERNAME=Adminportal
ARCGIS_PASSWORD="Adminportal2024*  "

# IDs se generan automáticamente en la primera publicación
# Luego de la primera ejecución, actualizar con los IDs generados:
FEATURE_LAYER_ID=
HOSTED_LAYER_ITEM_ID=

# Estrategia de actualización
ARCGIS_UPDATE_STRATEGY=overwrite

# Días hacia atrás para extraer datos
DIAS_ATRAS=7

# Microsoft Graph / SharePoint (compartido, misma config)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
